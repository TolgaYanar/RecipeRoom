                "mode": "raw",
                "raw": "{\n  \"username\": \"testsupplier\",\n  \"email\": \"supplier@example.com\",\n  \"password\": \"password123\",\n  \"business_name\": \"Green Valley Farms\",\n  \"address\": \"123 Farm Road\",\n  \"contact_number\": \"+905551234567\"\n}"
              }
