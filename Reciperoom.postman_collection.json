{
    "info": {
      "name": "RecipeRoom API",
      "description": "CS353 Group 7. Import into Postman or Thunder Client. Set base_url and token variables. Run Login first, copy token from response into the token variable.",
      "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
    },
    "variable": [
      {
        "key": "base_url",
        "value": "http://localhost:3001"
      },
      {
        "key": "token",
        "value": "PASTE_YOUR_TOKEN_HERE"
      }
    ],
    "item": [
      {
        "name": "Auth",
        "item": [
          {
            "name": "Login",
            "request": {
              "method": "POST",
              "header": [
                {
                  "key": "Content-Type",
                  "value": "application/json"
                }
              ],
              "url": "{{base_url}}/api/auth/login",
              "body": {
                "mode": "raw",
                "raw": "{\n  \"email\": \"cook@example.com\",\n  \"password\": \"password123\"\n}"
              },
              "description": "Returns { user, token }. Copy token into the collection token variable."
            },
            "event": [
              {
                "listen": "test",
                "script": {
                  "exec": [
                    "// Automatically save token to collection variable after login",
                    "if (pm.response.code === 200) {",
                    "    const body = pm.response.json();",
                    "    if (body.token) {",
                    "        pm.collectionVariables.set('token', body.token);",
                    "        console.log('Token saved automatically.');",
                    "    }",
                    "}"
                  ],
                  "type": "text/javascript"
                }
              }
            ]
          },
          {
            "name": "Register Home Cook",
            "request": {
              "method": "POST",
              "header": [
                {
                  "key": "Content-Type",
                  "value": "application/json"
                }
              ],
              "url": "{{base_url}}/api/auth/register/home-cook",
              "body": {
                "mode": "raw",
                "raw": "{\n  \"username\": \"testcook\",\n  \"email\": \"cook@example.com\",\n  \"password\": \"password123\",\n  \"target_daily_calories\": 2000,\n  \"primary_diet_goal\": \"Balanced\"\n}"
              }
            }
          },
